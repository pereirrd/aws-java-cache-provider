# Copy to .env and adjust for local development:
#   cp .env.example .env

# --- LocalStack (AWS control-plane emulation) ---
# ElastiCache API requires LocalStack Pro; Community supports Secrets Manager, STS, CloudWatch.
# See docs/localstack.md for the service matrix and validation steps.
AWS_JAVA_CACHE_LOCALSTACK_ENABLED=true
AWS_JAVA_CACHE_LOCALSTACK_HOST=localhost
AWS_JAVA_CACHE_LOCALSTACK_PORT=4566
AWS_JAVA_CACHE_LOCALSTACK_SERVICES=elasticache,secretsmanager,cloudwatch,sts
AWS_JAVA_CACHE_LOCALSTACK_DEBUG=0
AWS_JAVA_CACHE_LOCALSTACK_PERSISTENCE=0
# Required by localstack/localstack images from March 2026+ (docker compose and Testcontainers).
# Obtain a token at https://app.localstack.cloud
# See docs/integration-tests.md for the full integration test workflow.
# LOCALSTACK_AUTH_TOKEN=

# --- AWS SDK (used with LocalStack or real AWS) ---
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
# Optional explicit endpoint override (defaults to LocalStack when enabled above)
# AWS_JAVA_CACHE_AWS_ENDPOINT_URL=http://localhost:4566
# Standard SDK variable also supported:
# AWS_ENDPOINT_URL=http://localhost:4566

# --- Redis data plane (local container; separate from ElastiCache API in LocalStack) ---
AWS_JAVA_CACHE_REDIS_HOST=localhost
AWS_JAVA_CACHE_REDIS_PORT=6379
AWS_JAVA_CACHE_REDIS_TLS=false
AWS_JAVA_CACHE_REDIS_DATABASE=0
# AWS_JAVA_CACHE_REDIS_USERNAME=
# AWS_JAVA_CACHE_REDIS_PASSWORD=
# AWS_JAVA_CACHE_REDIS_TIMEOUT_MS=2000

# --- Memcached data plane (start with: docker compose --profile memcached up) ---
# AWS_JAVA_CACHE_MEMCACHED_PORT=11211
# AWS_JAVA_CACHE_MEMCACHED_NODES=localhost:11211
# AWS_JAVA_CACHE_MEMCACHED_OPERATION_TIMEOUT_MS=2500
